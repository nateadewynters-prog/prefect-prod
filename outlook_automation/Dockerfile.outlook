FROM python:3.13.5-slim

WORKDIR /opt/prefect/prod/code

# Copy the local requirements (from the outlook folder) and install
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy the context files INTO the specific outlook_automation subfolder
COPY . ./outlook_automation/

# Command to run your flow (Paths remain exactly the same as before)
CMD ["python", "outlook_automation/email_extraction_flow.py"]
