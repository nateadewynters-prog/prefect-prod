# ==========================================
# 🐍 Python Cache & Bytecode
# ==========================================
__pycache__/
*.py[cod]
*$py.class
*.so

# ==========================================
# 🧪 Testing & Coverage
# ==========================================
.pytest_cache/
.coverage
htmlcov/
.tox/

# ==========================================
# 📂 Local Data & State (CRITICAL)
# ==========================================
# We never commit raw PDFs, Excel files, or CSVs to Git.
data/inbox/*
data/processed/*
data/archive/*
data/failed/*
data/lookups/*
data/processed_ids.txt

# Keep the directory structure intact in Git, but ignore the contents
!data/inbox/.gitkeep
!data/processed/.gitkeep
!data/archive/.gitkeep
!data/failed/.gitkeep
!data/lookups/.gitkeep

# ==========================================
# 🔐 Secrets & Environments
# ==========================================
.env
.env.*
venv/
env/
.venv/

# ==========================================
# 💻 OS & IDE Files
# ==========================================
.DS_Store
.vscode/
.idea/
*.swp
